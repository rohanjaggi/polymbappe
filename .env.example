POLYMBAPPE_RANDOM_SEED=20260611
POLYMBAPPE_DATA_DIR=data
POLYMBAPPE_FRIENDLY_WEIGHT=0.3
POLYMBAPPE_DIXON_COLES_XI=0.0019

# Kaggle API token for the optional player-attributes ingest (EA FC / FM).
# Only needed for private/competition datasets or to lift anonymous rate limits;
# the default public dataset downloads without credentials. Get a token at
# kaggle.com -> Settings -> API -> Create New Token (or use ~/.kaggle/kaggle.json).
# NOTE: pydantic-settings only loads POLYMBAPPE_* keys, so these must be exported
# into the real environment before `polymbappe ingest`, e.g.  set -a; . .env; set +a
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_key
